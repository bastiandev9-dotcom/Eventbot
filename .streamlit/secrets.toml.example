# EventBot - Streamlit Cloud Secrets Template
# =============================================
# Copy isi file ini ke Streamlit Cloud:
# https://share.streamlit.io → Your app → Settings → Secrets

# Backend API URL (dari Railway/Render/Fly.io)
BACKEND_URL = "https://eventbot-production.up.railway.app"

# Optional: environment mode
APP_ENV = "production"

# Jangan tambahkan trailing slash di BACKEND_URL!
# ✅ Benar: https://api.eventbot.com
# ❌ Salah: https://api.eventbot.com/
