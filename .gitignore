# ============================================================
#  EventBot — .gitignore
# ============================================================

# ── Secrets & Environment ─────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets.json
credentials.json

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# ── Virtual Environments ──────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak
.venv.bak

# ── Testing & Coverage ────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test-results/
junit*.xml

# ── Type Checking ─────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ── Jupyter Notebooks ─────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── Streamlit ─────────────────────────────────────────────
frontend/.streamlit/secrets.toml
.streamlit/secrets.toml

# ── Logs ──────────────────────────────────────────────────
logs/
*.log
*.log.*
log/

# ── Uploads & Media ───────────────────────────────────────
media/
static/uploads/

# ── Database ──────────────────────────────────────────────
*.sqlite3
*.db
*.sql.bak
pgdata/
postgres-data/

# ── Docker ────────────────────────────────────────────────
docker-compose.override.yml
.docker/

# ── OS Files ──────────────────────────────────────────────
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.Trash-*

# ── IDEs & Editors ────────────────────────────────────────
# VSCode
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*.swn
*~
\#*\#
.#*

# ── Node (jika ada tooling frontend) ─────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm

# ── Misc ──────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
.sass-cache/
